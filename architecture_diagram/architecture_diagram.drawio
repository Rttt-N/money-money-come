  <diagram name="Round Lifecycle" id="lifecycle-1">
    <mxGraphModel dx="280" dy="352" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" background="#1a1a2e" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="lc2-title" value="Round Lifecycle — State Machine" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fontColor=#eeeef5;" parent="1" vertex="1">
          <mxGeometry x="300" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lc2-open" value="OPEN&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;Stable state (days/weeks)&#xa;&#xa;• Deposits allowed&#xa;• Withdrawals allowed (no penalty)&#xa;• Top-ups &amp; tier changes OK&#xa;&#xa;Note: contract also checks&#xa;block.timestamp &lt; endTime" style="rounded=1;whiteSpace=wrap;fillColor=#2a4a3a;strokeColor=#60b080;fontSize=11;align=left;spacingLeft=10;fontColor=#d8f5e5;arcSize=8;fontStyle=0;verticalAlign=top;spacingTop=6;" parent="1" vertex="1">
          <mxGeometry x="80" y="100" width="240" height="190" as="geometry" />
        </mxCell>
        <mxCell id="lc2-locked" value="LOCKED&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;Transient (same tx)&#xa;&#xa;• _harvestYield() runs&#xa;  — split yield per tier&#xa;• Withdraw = penalty&#xa;  (yield forfeited)" style="rounded=1;whiteSpace=wrap;fillColor=#3a2a2a;strokeColor=#d06060;fontSize=11;align=left;spacingLeft=10;fontColor=#f5d8d8;arcSize=8;fontStyle=0;verticalAlign=top;spacingTop=6;dashed=1;dashPattern=8 4;" parent="1" vertex="1">
          <mxGeometry x="510" y="100" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="lc2-drawing" value="DRAWING&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;Stable state (secs ~ mins)&#xa;&#xa;• Waiting for VRF callback&#xa;• Deposits blocked&#xa;• Withdrawals blocked&#xa;• No user actions possible" style="rounded=1;whiteSpace=wrap;fillColor=#2a3a5a;strokeColor=#5090d0;fontSize=11;align=left;spacingLeft=10;fontColor=#c8e0f5;arcSize=8;fontStyle=0;verticalAlign=top;spacingTop=6;" parent="1" vertex="1">
          <mxGeometry x="510" y="380" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="lc2-settled" value="SETTLED&#xa;━━━━━━━━━━━━━━━━━━━━━&#xa;Transient (same tx)&#xa;&#xa;• Winner selected&#xa;• Prize distributed&#xa;• loyaltyRounds++ for all&#xa;• Immediately → new round" style="rounded=1;whiteSpace=wrap;fillColor=#3a2a2a;strokeColor=#d06060;fontSize=11;align=left;spacingLeft=10;fontColor=#f5d8d8;arcSize=8;fontStyle=0;verticalAlign=top;spacingTop=6;dashed=1;dashPattern=8 4;" parent="1" vertex="1">
          <mxGeometry x="80" y="380" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="lc2-e1" value="performUpkeep()&#xa;Trigger: Chainlink Automation&#xa;or manual call (owner / anyone)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#60b080;fontSize=10;fontColor=#60b080;strokeWidth=2;labelBackgroundColor=#1a1a2e;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" parent="1" source="lc2-open" target="lc2-locked" edge="1">
          <mxGeometry x="0.1" y="10" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lc2-e1-cond" value="Condition:&#xa;block.timestamp ≥ endTime&#xa;&amp;&amp; state == OPEN&#xa;&amp;&amp; participants &gt; 0" style="text;html=1;fontSize=9;align=center;fontColor=#90c0a0;fontStyle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="345" y="85" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lc2-e2" value="VRF request sent&#xa;(same tx as LOCKED)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d06060;fontSize=10;fontColor=#d06060;strokeWidth=2;dashed=1;dashPattern=6 3;labelBackgroundColor=#1a1a2e;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="lc2-locked" target="lc2-drawing" edge="1">
          <mxGeometry x="-0.15" y="10" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lc2-e2-note" value="⚡ Instant&#xa;(within same tx)" style="text;html=1;fontSize=9;align=left;fontColor=#d09090;fontStyle=3;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="765" y="300" width="110" height="35" as="geometry" />
        </mxCell>
        <mxCell id="lc2-e3" value="fulfillRandomWords()&#xa;Chainlink VRF callback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#5090d0;fontSize=10;fontColor=#5090d0;strokeWidth=2;labelBackgroundColor=#1a1a2e;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="lc2-drawing" target="lc2-settled" edge="1">
          <mxGeometry y="10" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
